# --- Vercel Production (required on Vercel) ---

# Supabase → Settings → API → Project URL (ONLY this, no /rest/v1, no dashboard link)
SUPABASE_URL=https://abcdefghijklmnop.supabase.co

# Supabase → Settings → API → service_role → Secret (starts with eyJ...)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Do NOT prefix server keys with VITE_ — those are build-time frontend vars only.

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

PRODUCTS_API_SECRET=change-me-use-a-long-random-string
VITE_PRODUCTS_API_SECRET=change-me-use-a-long-random-string
VITE_ADMIN_PASSWORD=change-me-strong-password

# --- Windows VPS / local server (SQLite — leave Supabase empty) ---

# NODE_ENV=production
# PORT=4020
# HOST=0.0.0.0

# Full guides:
#   Vercel  → VERCEL_DEPLOY.md
#   VPS     → DEPLOY.md
