# --- Database (choose one) ---

# Option A — Supabase (recommended for production / Vercel)
# Create a free project at https://supabase.com, run supabase/schema.sql in SQL Editor
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Option B — Local SQLite (automatic when Supabase is not set)
# Data file: db/products.db (created on first run, migrates from db/products.json if present)

# Protect admin product writes (same value in Vite for the admin panel)
PRODUCTS_API_SECRET=change-me-in-production
VITE_PRODUCTS_API_SECRET=change-me-in-production

# Admin panel login password
VITE_ADMIN_PASSWORD=change-me-in-production

# Cloudinary (optional — persistent image uploads in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
